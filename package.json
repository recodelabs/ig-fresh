{
  "name": "ig-fresh",
  "version": "0.1.0",
  "description": "A modern, searchable static site generator for HL7 FHIR IG Publisher output",
  "license": "Apache-2.0",
  "type": "module",
  "bin": { "ig-fresh": "dist/cli.js" },
  "files": ["dist", "assets"],
  "scripts": {
    "build": "tsc && npm run css",
    "css": "tailwindcss -i src/ui/site.css -o dist/ui/site.built.css --minify",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "cheerio": "^1.0.0",
    "fuse.js": "^7.0.0",
    "pagefind": "^1.3.0",
    "preact": "^10.24.0",
    "preact-render-to-string": "^6.5.0",
    "shiki": "^1.24.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^20.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
